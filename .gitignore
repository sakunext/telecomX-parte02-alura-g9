# ============================================================================
# TelecomX - Parte 2: .gitignore
# ============================================================================

# Archivos de datos generados
*.csv
*.pkl
*.json

# Excepciones: Mantener archivos importantes (descomenta si necesitas versionarlos)
# !datos_tratados.csv
# !modelos_comparacion.csv

# Jupyter Notebook
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Entornos virtuales
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log

# Outputs de modelos (si no quieres versionar)
models/
*.h5
*.hdf5

# Datos sensibles
credentials.json
config.json
*.env
.env

# Archivos temporales
tmp/
temp/
*.tmp
*.bak
*.backup

# Reportes y outputs
reports/*.html
reports/*.pdf
outputs/

# Cache
.cache/
.pytest_cache/
